
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- COLLECTION RULES ---

    // Users can only read and write their own profile and progress
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      match /lessonProgress/{lessonId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Admin users collection
    match /adminUsers/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Access codes are read-only for verification, write for authenticated users during activation
    match /accessCodes/{codeId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Lessons are globally readable, only admin (system) can write
    match /lessons/{lessonId} {
      allow read: if true;
      allow write: if false; 
    }
  }
}
