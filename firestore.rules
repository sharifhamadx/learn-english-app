
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid));
    }

    // --- COLLECTION RULES ---

    // Users: Owners can manage their data, Admins have full control
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
      
      match /lessonProgress/{lessonId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // Admin users collection: Only the admin themselves or other admins can access
    match /adminUsers/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // Access codes: 
    // - Anyone can read (to check validity during login)
    // - Only admins can CREATE or DELETE
    // - Logged in users can only UPDATE to activate the code (mark as used)
    match /accessCodes/{codeId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isSignedIn() && (
        isAdmin() || 
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['usedByUid', 'activatedAt']))
      );
    }

    // Lessons: Globally readable, only admin can modify
    match /lessons/{lessonId} {
      allow read: if true;
      allow write: if isAdmin(); 
    }
  }
}
