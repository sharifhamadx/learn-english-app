
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a user of the application.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "username": { "type": "string" },
        "registrationDate": { "type": "string", "format": "date-time" },
        "plan": { "type": "string", "enum": ["free", "silver", "bronze", "gold"], "description": "The current subscription tier of the user." },
        "accessCode": { "type": "string" }
      },
      "required": ["id"]
    },
    "AccessCode": {
      "title": "AccessCode",
      "type": "object",
      "description": "A unique serial code to grant access to the app, locked to a specific device.",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string", "description": "The serial string (e.g., 7710202611)." },
        "plan": { "type": "string", "enum": ["silver", "bronze", "gold"] },
        "note": { "type": "string", "description": "Subscriber name or note." },
        "isActive": { "type": "boolean" },
        "usedByUid": { "type": "string", "description": "The Firebase UID of the device that first activated this code." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "code", "plan", "isActive", "createdAt"]
    }
  },
  "auth": {
    "providers": ["anonymous"]
  },
  "firestore": {
    "/accessCodes/{codeId}": {
      "schema": { "$ref": "#/entities/AccessCode" },
      "description": "Collection of valid access codes."
    },
    "/adminUsers/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Admin privilege marker."
    },
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Standard user profiles with plan and device binding info."
    }
  }
}
