
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a user of the application.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "username": { "type": "string" },
        "registrationDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "username", "registrationDate"]
    },
    "AccessCode": {
      "title": "AccessCode",
      "type": "object",
      "description": "A unique code generated by the admin to grant full access to the app.",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string", "description": "The actual string used to unlock the app." },
        "note": { "type": "string", "description": "Admin note, e.g., 'Student: Ahmed'" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "code", "isActive", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/accessCodes/{codeId}": {
      "schema": { "$ref": "#/entities/AccessCode" },
      "description": "Collection of valid access codes managed by the admin."
    },
    "/adminUsers/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Marker collection for admin privileges."
    }
  }
}
